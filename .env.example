BOT_TOKEN=
CHANNEL_USERNAME=@claudedry
# chat_id технического чата для модерации фидбэка (инструменты/промпты от пользователей).
# Пусто = фидбэк только логируется, не отправляется никуда. Для групп ID ОТРИЦАТЕЛЬНЫЙ
# (например -5386251457) — узнать: добавить бота в группу, написать в ней "/start@<bot_username>"
# (упоминание нужно из-за privacy mode) и посмотреть chat.id через getUpdates.
TECH_CHAT_ID=
DATABASE_URL=postgresql://user:pass@localhost:5432/botyard
REDIS_URL=redis://localhost:6379/0
